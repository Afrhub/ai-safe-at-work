# Normalise line endings — LF in repo, native on checkout-as-OS-default
* text=auto eol=lf

# Binary types (just in case any land later)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.pdf  binary
*.zip  binary
*.woff  binary
*.woff2 binary

# Force LF on these regardless
*.sh   text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.xml  text eol=lf
*.json text eol=lf
*.py   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
